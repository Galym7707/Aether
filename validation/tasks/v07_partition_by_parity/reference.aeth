function appendInt(xs: List<Int>, x: Int) returns List<Int>
  effects pure
do
  return append(xs, x)
end

function partition(xs: List<Int>) returns Map<String, List<Int>>
  effects pure
do
  var m: Map<String, List<Int>> = {"even": [], "odd": []}
  for x in xs do
    if x % 2 == 0 then
      m = set(m, "even", appendInt(unwrapOrElse(get(m, "even"), []), x))
    else
      m = set(m, "odd", appendInt(unwrapOrElse(get(m, "odd"), []), x))
    end
  end
  return m
end

function showList(xs: List<Int>) returns String
  effects pure
do
  var parts: List<String> = []
  for x in xs do
    parts = append(parts, intToString(x))
  end
  return join(["[", join(parts, ","), "]"], "")
end

function render(m: Map<String, List<Int>>) returns String
  effects pure
do
  let evens: List<Int> = unwrapOrElse(get(m, "even"), [])
  let odds: List<Int> = unwrapOrElse(get(m, "odd"), [])
  return join(["even=", showList(evens), " odd=", showList(odds)], "")
end

function main() returns Unit
  effects log
do
  print(render(partition([1, 2, 3, 4, 5])))
  print(render(partition([])))
  print(render(partition([2, 4, 6])))
  print(render(partition([1])))
end
