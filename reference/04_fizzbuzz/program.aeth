function fizzbuzz(n: Int) returns String
  requires n >= 1
  effects pure
do
  if n % 15 == 0 then
    return "FizzBuzz"
  elif n % 3 == 0 then
    return "Fizz"
  elif n % 5 == 0 then
    return "Buzz"
  else
    return intToString(n)
  end
end

function main() returns Unit
  effects log
do
  for i in range(1, 16) do
    print(fizzbuzz(i))
  end
end
