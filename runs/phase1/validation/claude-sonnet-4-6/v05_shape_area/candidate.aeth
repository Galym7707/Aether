union Shape do
  case Square(side: Int)
  case Rectangle(width: Int, height: Int)
  case Triangle(base: Int, height: Int)
end

function area(s: Shape) returns Int
  effects pure
do
  match s do
    case Square(side) do
      return side * side
    end
    case Rectangle(width, height) do
      return width * height
    end
    case Triangle(base, height) do
      return base * height / 2
    end
  end
end

function main() returns Unit
  effects log
do
  print(intToString(area(Shape.Square(4))))
  print(intToString(area(Shape.Rectangle(3, 5))))
  print(intToString(area(Shape.Triangle(4, 6))))
  print(intToString(area(Shape.Square(0))))
end
