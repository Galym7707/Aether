union Op do
  case Add
  case Sub
  case Mul
end

function apply(op: Op, a: Int, b: Int) returns Int
  effects pure
do
  match op do
    case Add() do
      return a + b
    end
    case Sub() do
      return a - b
    end
    case Mul() do
      return a * b
    end
  end
end

function main() returns Unit
  effects log
do
  let r1: Int = apply(Op.Add(), 3, 4)
  let r2: Int = apply(Op.Sub(), 10, 7)
  let r3: Int = apply(Op.Mul(), 6, 7)
  let r4: Int = apply(Op.Add(), -5, 5)
  print(intToString(r1))
  print(intToString(r2))
  print(intToString(r3))
  print(intToString(r4))
end
