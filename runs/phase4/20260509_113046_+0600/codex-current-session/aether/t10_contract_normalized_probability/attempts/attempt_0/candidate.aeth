function validWeights?(weights: List<Int>) returns Bool
  effects pure
do
  if empty?(weights) then
    return false
  end
  var total: Int = 0
  for w in weights do
    if w < 0 then
      return false
    end
    total = total + w
  end
  return total == 100
end

function chooseBucket(weights: List<Int>, threshold: Int) returns Int
  requires validWeights?(weights)
  effects pure
do
  var cumulative: Int = 0
  var i: Int = 0
  while i < length(weights) do
    cumulative = cumulative + weights[i]
    if threshold < cumulative then
      return i
    end
    i = i + 1
  end
  return length(weights) - 1
end

function main() returns Unit
  effects log
do
  chooseBucket([50, -20, 70], 25)
end
