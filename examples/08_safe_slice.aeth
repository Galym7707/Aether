function describeSlice(res: Result<List<Int>, String>) returns String
  effects pure
do
  match res do
    case Ok(part) do
      return join([intToString(length(part)), ":", intToString(part[0]), ",", intToString(part[1])], "")
    end
    case Err(message) do
      return message
    end
  end
end

function main() returns Unit
  effects log
do
  let xs: List<Int> = [10, 20, 30, 40]
  print(describeSlice(safeSlice(xs, 1, 3)))
  print(describeSlice(safeSlice(xs, 3, 9)))
end
