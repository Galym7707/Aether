function reverseString(s: String) returns String
  effects pure
do
  var out: List<String> = []
  var i: Int = length(s) - 1
  while i >= 0 do
    out = append(out, slice(s, i, i + 1))
    i = i - 1
  end
  return join(out, "")
end

function main() returns Unit
  effects log
do
  print(reverseString("aether"))
  print(reverseString(""))
  print(reverseString("a"))
  print(reverseString("racecar"))
end
