type BoundedCount = Int where self >= 0 and self <= 1000

function repeatCost(count: BoundedCount) returns Int
  effects pure
do
  var total: Int = 0
  var i: Int = 0
  while i < count do
    total = total + 1
    i = i + 1
  end
  return total
end

function main() returns Unit
  effects log
do
  print(intToString(repeatCost(5000)))
end
